---
interface Props {
  icon: string;
  value: string;
  label: string;
  trend: string;
  trendUp: boolean;
}

const { icon, value, label, trend, trendUp } = Astro.props;
---

<div class="stats-card">
  <div class="stats-card-top">
    <div class="stats-icon">{icon}</div>
    <span class={`stats-trend ${trendUp ? 'trend-up' : 'trend-down'}`}>{trend}</span>
  </div>
  <div class="stats-value">{value}</div>
  <div class="stats-label">{label}</div>
</div>

<style>
  .stats-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 2px 12px rgba(45, 74, 53, 0.08);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stats-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .stats-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--color-primary-tint);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .stats-trend {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 20px;
  }

  .trend-up {
    color: #2D7A3E;
    background: var(--color-primary-tint);
  }

  .trend-down {
    color: var(--color-error);
    background: var(--color-error-tint);
  }

  .stats-value {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.1;
  }

  .stats-label {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-muted);
    font-weight: 500;
  }
</style>
