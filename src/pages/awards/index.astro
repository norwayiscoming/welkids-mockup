---
import MainLayout from '../../layouts/MainLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import gallery from '../../data/gallery.json';

const awardLabelMap: Record<string, string> = {
  first: '🥇 Giải Nhất',
  second: '🥈 Giải Nhì',
  third: '🥉 Giải Ba',
};

const winners = gallery.filter((item) => item.award !== null);
const entries = gallery.filter((item) => item.award === null);

// Sort winners: first, second, third
const awardOrder: Record<string, number> = { first: 1, second: 2, third: 3 };
winners.sort((a, b) => (awardOrder[a.award!] ?? 99) - (awardOrder[b.award!] ?? 99));
---

<MainLayout title="Giải Thưởng & Cuộc Thi">

  <!-- ═══ HERO BANNER ═══ -->
  <section class="awards-hero">
    <div class="awards-hero-bg">
      <div class="blob blob-yellow" style="width:300px;height:300px;top:-80px;right:-60px;"></div>
      <div class="blob blob-white" style="width:200px;height:200px;bottom:-40px;left:10%;"></div>
      <div class="blob blob-green" style="width:180px;height:180px;top:20%;left:-40px;"></div>
    </div>
    <div class="container text-center" style="position:relative;z-index:1;">
      <div class="awards-hero-icon animate-float">🏆</div>
      <h1 class="awards-hero-title">Giải Thưởng & Cuộc Thi</h1>
      <p class="awards-hero-subtitle">Bộ sưu tập ảnh AI đã tạo và các câu chuyện truyền cảm hứng</p>
    </div>
  </section>

  <!-- ═══ WINNERS PODIUM ═══ -->
  <section class="winners-section">
    <div class="container">
      <div class="winners-label">
        <span class="winners-label-dot"></span>
        <span>Top Winners</span>
      </div>

      <div class="podium">
        {winners.map((w, i) => {
          const podiumClass = i === 0 ? 'podium-first' : i === 1 ? 'podium-second' : 'podium-third';
          const rankEmoji = i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉';
          const rankLabel = i === 0 ? 'Giải Nhất' : i === 1 ? 'Giải Nhì' : 'Giải Ba';
          return (
            <div class={`podium-card ${podiumClass}${w.hasVideo ? ' has-video' : ''}`} data-name={w.name} data-career={w.career}>
              <div class="podium-rank">
                <span class="podium-rank-emoji">{rankEmoji}</span>
              </div>
              <div class="podium-avatar">
                <div class="podium-avatar-inner">
                  <span class="podium-avatar-emoji">🎨</span>
                </div>
                {w.hasVideo && (
                  <div class="podium-play">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                )}
              </div>
              <div class="podium-info">
                <span class="podium-name">{w.name}</span>
                <span class="podium-career">{w.career}</span>
                <span class="podium-rank-label">{rankLabel}</span>
              </div>
              <div class="podium-ticket">{w.ticket}</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══ FILTER + GALLERY ═══ -->
  <section class="section gallery-section">
    <div class="container">
      <div class="gallery-header">
        <h2 class="gallery-title">Tất Cả Bài Dự Thi</h2>
        <div class="filter-tabs">
          <button class="filter-tab active" data-filter="all">Tất cả</button>
          <button class="filter-tab" data-filter="first">🥇 Giải Nhất</button>
          <button class="filter-tab" data-filter="second">🥈 Giải Nhì</button>
          <button class="filter-tab" data-filter="third">🥉 Giải Ba</button>
        </div>
      </div>

      <div class="gallery-grid" id="galleryGrid">
        {gallery.map((item) => (
          <div
            class={`gallery-item${item.hasVideo ? ' has-video' : ''}${item.award ? ' is-winner' : ''}`}
            data-award={item.award ?? 'none'}
            data-name={item.name}
            data-career={item.career}
          >
            <div class="gallery-image">
              <div class="gallery-placeholder">
                <span class="gallery-emoji">🎨</span>
              </div>
              {item.award && (
                <span class="award-badge">
                  {awardLabelMap[item.award]}
                </span>
              )}
              {item.hasVideo && (
                <div class="video-overlay">
                  <div class="play-btn-circle">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              )}
            </div>
            <div class="gallery-info">
              <span class="gallery-name">{item.name}</span>
              <span class="gallery-career">{item.career}</span>
              <span class="gallery-ticket">{item.ticket}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VIDEO MODAL ═══ -->
  <div class="modal-overlay" id="videoModal" aria-hidden="true">
    <div class="modal-panel leaf-glass">
      <div class="modal-video">
        <span class="modal-play-icon">▶</span>
      </div>
      <div class="modal-story">
        <p class="modal-name" id="modalName"></p>
        <p class="modal-career" id="modalCareer"></p>
        <p class="modal-desc">Đây là câu chuyện truyền cảm hứng về ước mơ nghề nghiệp của bé. Hãy cùng xem hành trình đặc biệt này!</p>
      </div>
      <button class="modal-close" id="modalClose" aria-label="Đóng">✕</button>
    </div>
  </div>

  <!-- ═══ BOTTOM CTA ═══ -->
  <section class="cta-section">
    <div class="cta-bg">
      <div class="blob blob-green" style="width:250px;height:250px;top:-80px;left:-60px;"></div>
      <div class="blob blob-yellow" style="width:200px;height:200px;bottom:-60px;right:-40px;"></div>
    </div>
    <div class="container text-center" style="position:relative;z-index:1;">
      <div class="cta-icon">✨</div>
      <h2 class="cta-title">Tham Gia Cuộc Thi</h2>
      <p class="cta-subtitle">Tạo ảnh nghề nghiệp cho bé và có cơ hội nhận giải thưởng hấp dẫn</p>
      <a href="/ai-generator/" class="cta-btn">
        Tham gia ngay
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

</MainLayout>

<style>
  /* ═══════════════════════════════════════
     HERO BANNER
     ═══════════════════════════════════════ */
  .awards-hero {
    position: relative;
    overflow: hidden;
    padding: 100px 0 48px;
    background: linear-gradient(160deg, #FFF8E1 0%, #F8D76E 30%, #F5C842 60%, #FFB74D 100%);
  }

  .awards-hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .awards-hero-icon {
    font-size: 56px;
    margin-bottom: 16px;
  }

  .awards-hero-title {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 800;
    color: #4A3000;
    margin-bottom: 8px;
    text-shadow: 0 2px 12px rgba(213, 165, 32, 0.2);
  }

  .awards-hero-subtitle {
    font-size: 17px;
    color: #6B5010;
    max-width: 500px;
    margin: 0 auto;
    font-weight: 500;
  }

  /* ═══════════════════════════════════════
     WINNERS PODIUM
     ═══════════════════════════════════════ */
  .winners-section {
    padding: 48px 0 32px;
    background: var(--color-cream);
  }

  .winners-label {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    margin-bottom: 32px;
    font-size: 13px;
    font-weight: 700;
    color: var(--color-accent-dark);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .winners-label-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(245, 200, 66, 0.6);
  }

  .podium {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .podium-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 20px 20px;
    border-radius: 24px;
    position: relative;
    transition: transform 0.25s ease;
    cursor: default;
    text-align: center;
  }

  .podium-card.has-video { cursor: pointer; }
  .podium-card:hover { transform: translateY(-6px); }

  /* First place — largest, gold gradient */
  .podium-first {
    background: linear-gradient(180deg, #FFF8E1 0%, rgba(245,200,66,0.25) 50%, rgba(232,170,32,0.15) 100%);
    box-shadow: 0 4px 0 rgba(213,165,32,0.2), 0 8px 32px rgba(213,165,32,0.15);
    padding: 32px 28px 24px;
    flex: 0 0 240px;
    order: 2;
  }

  .podium-first .podium-avatar-inner {
    width: 100px;
    height: 100px;
    font-size: 40px;
    border: 3px solid var(--color-accent);
    box-shadow: 0 4px 20px rgba(245,200,66,0.3);
  }

  .podium-first .podium-rank-emoji { font-size: 32px; }

  /* Second place */
  .podium-second {
    background: linear-gradient(180deg, #F0F5F1 0%, rgba(212,237,218,0.3) 100%);
    box-shadow: 0 2px 0 var(--color-leaf-gray), 0 4px 20px rgba(45,74,53,0.06);
    flex: 0 0 200px;
    order: 1;
  }

  .podium-second .podium-avatar-inner {
    width: 80px;
    height: 80px;
    font-size: 32px;
    border: 2px solid var(--color-primary-light);
  }

  /* Third place */
  .podium-third {
    background: linear-gradient(180deg, #FFF8E1 0%, rgba(255,183,77,0.15) 100%);
    box-shadow: 0 2px 0 rgba(213,165,32,0.1), 0 4px 20px rgba(213,165,32,0.06);
    flex: 0 0 200px;
    order: 3;
  }

  .podium-third .podium-avatar-inner {
    width: 80px;
    height: 80px;
    font-size: 32px;
    border: 2px solid var(--color-warm);
  }

  .podium-rank {
    margin-bottom: 12px;
  }

  .podium-rank-emoji { font-size: 24px; }

  .podium-avatar {
    position: relative;
    margin-bottom: 14px;
  }

  .podium-avatar-inner {
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary-tint), var(--color-primary-light));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .podium-play {
    position: absolute;
    bottom: -4px;
    right: -4px;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4A3000;
    box-shadow: 0 2px 8px rgba(245,200,66,0.4);
  }

  .podium-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .podium-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-heading);
  }

  .podium-career {
    font-size: 13px;
    color: var(--color-primary);
    font-weight: 600;
  }

  .podium-rank-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 4px;
  }

  .podium-ticket {
    font-size: 10px;
    color: var(--color-muted);
    margin-top: 8px;
  }

  /* ═══════════════════════════════════════
     GALLERY
     ═══════════════════════════════════════ */
  .gallery-section {
    background: var(--color-mint-gray);
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .gallery-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
  }

  .gallery-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: var(--color-heading);
  }

  .filter-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-tab {
    padding: 7px 16px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    background: rgba(255,255,255,0.7);
    color: var(--color-body);
    transition: all 0.2s ease;
  }

  .filter-tab:hover { background: rgba(255,255,255,0.9); color: var(--color-heading); }
  .filter-tab.active { background: var(--color-primary); color: #fff; box-shadow: 0 2px 0 var(--color-primary-dark); }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .gallery-item {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(45,74,53,0.1);
  }

  .gallery-item.has-video { cursor: pointer; }

  .gallery-item.is-winner {
    box-shadow: 0 2px 0 rgba(213,165,32,0.15), 0 4px 16px rgba(213,165,32,0.08);
  }

  .gallery-image {
    position: relative;
    padding-top: 100%;
    overflow: hidden;
  }

  .gallery-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-tint) 0%, rgba(125,192,138,0.3) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .is-winner .gallery-placeholder {
    background: linear-gradient(135deg, #FFF8E1 0%, #F8D76E 60%, #FFB74D 100%);
  }

  .gallery-emoji { font-size: 36px; opacity: 0.6; }

  .award-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 700;
    color: #4A3000;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 2;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.15);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 1;
  }

  .gallery-item.has-video:hover .video-overlay { opacity: 1; }

  .play-btn-circle {
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-heading);
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .play-btn-circle svg { margin-left: 2px; }

  .gallery-info {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gallery-name { font-size: 14px; font-weight: 700; color: var(--color-heading); }
  .gallery-career { font-size: 12px; color: var(--color-primary); font-weight: 600; }
  .gallery-ticket { font-size: 11px; color: var(--color-muted); }

  /* ═══════════════════════════════════════
     MODAL
     ═══════════════════════════════════════ */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .modal-overlay.visible { opacity: 1; pointer-events: all; }

  .modal-panel {
    position: relative;
    max-width: 560px;
    width: 100%;
    border-radius: var(--radius-card);
    padding: 0;
    overflow: hidden;
  }

  .modal-video {
    position: relative;
    padding-top: 56.25%;
    background: linear-gradient(135deg, #1a3d22, #2D4A35);
  }

  .modal-play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 44px;
    color: rgba(255,255,255,0.7);
  }

  .modal-story { padding: 24px; display: flex; flex-direction: column; gap: 6px; }
  .modal-name { font-size: 17px; font-weight: 700; color: var(--color-heading); }
  .modal-career { font-size: 14px; color: var(--color-primary); font-weight: 600; }
  .modal-desc { font-size: 14px; color: var(--color-muted); line-height: 1.6; margin-top: 4px; }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(8px);
    border: none;
    font-size: 16px;
    color: var(--color-heading);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .modal-close:hover { background: rgba(255,255,255,0.9); }

  /* ═══════════════════════════════════════
     CTA
     ═══════════════════════════════════════ */
  .cta-section {
    position: relative;
    overflow: hidden;
    padding: 72px 0;
    background: linear-gradient(160deg, #E8F5E9 0%, #D4EDDA 50%, #FFF8E1 100%);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 8px;
  }

  .cta-subtitle {
    font-size: 16px;
    color: var(--color-body);
    max-width: 450px;
    margin: 0 auto 24px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    color: #4A3000;
    background: linear-gradient(180deg, #F8D76E 0%, #F5C842 50%, #E8B830 100%);
    box-shadow: 0 2px 0 #D4A520, 0 4px 16px rgba(213,165,32,0.25);
    text-decoration: none;
    transition: transform 0.15s ease, filter 0.15s ease;
  }

  .cta-btn:hover { transform: translateY(-2px); filter: brightness(1.04); }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .podium-first { flex: 0 0 200px; }
    .podium-second, .podium-third { flex: 0 0 170px; }
  }

  @media (max-width: 768px) {
    .awards-hero { padding: 90px 0 40px; }
    .awards-hero-title { font-size: 28px; }
    .podium { gap: 12px; }
    .podium-first { flex: 0 0 160px; padding: 24px 16px 20px; }
    .podium-second, .podium-third { flex: 0 0 130px; padding: 20px 12px 16px; }
    .podium-first .podium-avatar-inner { width: 72px; height: 72px; font-size: 32px; }
    .podium-second .podium-avatar-inner,
    .podium-third .podium-avatar-inner { width: 56px; height: 56px; font-size: 24px; }
    .podium-name { font-size: 13px; }
    .podium-career { font-size: 11px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-header { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .podium { flex-wrap: wrap; }
    .podium-first { order: 1; flex: 1 1 100%; }
    .podium-second { order: 2; flex: 1 1 45%; }
    .podium-third { order: 3; flex: 1 1 45%; }
  }
</style>

<script>
  // ---- Filter Tabs ----
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const filter = tab.dataset.filter;

      items.forEach((item) => {
        if (filter === 'all') {
          item.style.display = '';
        } else {
          item.style.display = item.dataset.award === filter ? '' : 'none';
        }
      });
    });
  });

  // ---- Video Modal ----
  const modal = document.getElementById('videoModal') as HTMLElement;
  const modalName = document.getElementById('modalName') as HTMLElement;
  const modalCareer = document.getElementById('modalCareer') as HTMLElement;
  const modalClose = document.getElementById('modalClose') as HTMLButtonElement;

  function openModal(name: string, career: string) {
    modalName.textContent = name;
    modalCareer.textContent = career;
    modal.classList.add('visible');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('visible');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Gallery items with video
  items.forEach((item) => {
    if (item.classList.contains('has-video')) {
      item.addEventListener('click', () => {
        openModal(item.dataset.name ?? '', item.dataset.career ?? '');
      });
    }
  });

  // Podium cards with video
  document.querySelectorAll<HTMLElement>('.podium-card.has-video').forEach((card) => {
    card.addEventListener('click', () => {
      openModal(card.dataset.name ?? '', card.dataset.career ?? '');
    });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('visible')) closeModal(); });
</script>
