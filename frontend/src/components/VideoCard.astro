---
interface Props {
  title: string;
  category: string;
  duration: string;
  description: string;
}

const { title, category, duration, description } = Astro.props;
---

<div class="video-card leaf-glass">
  <!-- Thumbnail -->
  <div class="video-thumbnail">
    <div class="thumbnail-bg"></div>
    <button class="play-btn frost-glass" aria-label="Play video">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </button>
    <span class="duration-pill frost-glass">{duration}</span>
  </div>

  <!-- Body -->
  <div class="video-body">
    <span class="video-category">{category}</span>
    <h3 class="video-title">{title}</h3>
    <p class="video-description">{description}</p>
  </div>
</div>

<style>
  .video-card {
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(61, 139, 79, 0.16);
  }

  .video-thumbnail {
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 ratio */
    overflow: hidden;
    flex-shrink: 0;
  }

  .thumbnail-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-tint) 0%, var(--color-primary-light) 60%, var(--color-primary) 100%);
  }

  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-heading);
    cursor: pointer;
    border: none;
    transition: transform 0.2s ease, background 0.2s ease;
    z-index: 1;
  }

  .play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background: rgba(255, 255, 255, 0.55);
  }

  .play-btn svg {
    margin-left: 3px; /* optical centering for play icon */
  }

  .duration-pill {
    position: absolute;
    bottom: 10px;
    right: 10px;
    border-radius: 50px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-heading);
    z-index: 1;
    font-family: var(--font-body);
  }

  .video-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .video-category {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    font-family: var(--font-body);
  }

  .video-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.35;
  }

  .video-description {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
