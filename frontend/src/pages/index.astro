---
import MainLayout from '../layouts/MainLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Button from '../components/Button.astro';
import GlassPanel from '../components/GlassPanel.astro';
import Card from '../components/Card.astro';
---

<MainLayout
  title="WelKids — Vitamin Tăng Trưởng Toàn Diện Cho Bé"
  description="WelKids cung cấp vitamin và sản phẩm chăm sóc sức khỏe chất lượng cao dành cho trẻ em."
>

  <!-- ===== 1. Hero Section ===== -->
  <section class="hero bg-gradient-hero fade-up">
    <!-- Decorative blobs -->
    <div class="blob blob-green hero-blob-1" aria-hidden="true"></div>
    <div class="blob blob-yellow hero-blob-2" aria-hidden="true"></div>
    <div class="blob blob-white hero-blob-3" aria-hidden="true"></div>

    <div class="container hero-content text-center">
      <!-- Campaign badge -->
      <div class="hero-badge frost-glass">
        <span class="badge-dot" aria-hidden="true"></span>
        <span class="badge-text">Campaign 2026</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-title">Bộ Tứ Vàng WelKids AD₃ E K₂</h1>

      <!-- Subtitle -->
      <p class="hero-subtitle">Vững nền miễn dịch · Bé khỏe vươn cao</p>

      <!-- CTA Buttons -->
      <div class="hero-actions">
        <a href="#san-pham" class="btn-hero-primary">Khám phá ngay</a>
        <a href="#videos" class="btn-hero-secondary">
          <span class="play-icon" aria-hidden="true">▶</span>
          Xem video
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 2. Product Intro Section ===== -->
  <section id="san-pham" class="section fade-up">
    <div class="container">
      <SectionHeader
        badge="Sản phẩm nổi bật"
        title="Sản Phẩm WelKids AD₃ E K₂"
        subtitle="Công thức kết hợp 4 vitamin thiết yếu giúp bé phát triển toàn diện — từ xương, mắt đến hệ miễn dịch."
        align="center"
      />

      <div class="product-grid">
        <!-- Left: image placeholder -->
        <div class="product-image-placeholder">
          <div class="product-image-inner">
            <span class="product-image-label">WelKids AD₃ E K₂</span>
            <span class="product-image-sub">Vitamin Tăng Trưởng Toàn Diện</span>
          </div>
        </div>

        <!-- Right: description + vitamin cards -->
        <div class="product-info">
          <p class="product-description">
            WelKids AD₃ E K₂ là sự kết hợp hoàn hảo của bộ tứ vitamin vàng, được bào chế đặc biệt
            dành cho trẻ em. Sản phẩm giúp hỗ trợ hệ miễn dịch vững chắc, phát triển xương và
            mắt khỏe mạnh, đồng thời tăng cường khả năng hấp thu canxi tự nhiên.
          </p>

          <div class="vitamin-grid">
            <!-- Vitamin A -->
            <div class="vitamin-card leaf-glass">
              <div class="vitamin-icon">A</div>
              <div class="vitamin-info">
                <span class="vitamin-name">Vitamin A</span>
                <span class="vitamin-benefit">Bảo vệ thị lực & da</span>
              </div>
            </div>

            <!-- Vitamin D3 -->
            <div class="vitamin-card leaf-glass">
              <div class="vitamin-icon">D₃</div>
              <div class="vitamin-info">
                <span class="vitamin-name">Vitamin D₃</span>
                <span class="vitamin-benefit">Tăng cường hấp thu canxi</span>
              </div>
            </div>

            <!-- Vitamin E -->
            <div class="vitamin-card leaf-glass">
              <div class="vitamin-icon">E</div>
              <div class="vitamin-info">
                <span class="vitamin-name">Vitamin E</span>
                <span class="vitamin-benefit">Chống oxy hóa mạnh</span>
              </div>
            </div>

            <!-- Vitamin K2 -->
            <div class="vitamin-card leaf-glass">
              <div class="vitamin-icon">K₂</div>
              <div class="vitamin-info">
                <span class="vitamin-name">Vitamin K₂</span>
                <span class="vitamin-benefit">Phát triển xương chắc khỏe</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 3. Campaign Overview Section ===== -->
  <section class="section bg-gradient-green campaign-section fade-up" style="position: relative; overflow: hidden;">
    <!-- Decorative blobs -->
    <div class="blob blob-green campaign-blob-1" aria-hidden="true"></div>
    <div class="blob blob-yellow campaign-blob-2" aria-hidden="true"></div>

    <div class="container">
      <SectionHeader
        badge="Hoạt động chiến dịch"
        title="Hành Trình Khám Phá Cùng WelKids"
        subtitle="Tham gia các hoạt động thú vị, khám phá sức khỏe và nhận những phần quà hấp dẫn từ WelKids."
        align="center"
      />

      <div class="campaign-grid">
        <Card
          title="Kiểm tra dinh dưỡng"
          description="Đánh giá tình trạng dinh dưỡng của bé và nhận tư vấn cá nhân hóa từ chuyên gia."
          icon="🩺"
          badge="Miễn phí"
          badgeVariant="primary"
          gradient="linear-gradient(135deg, #D4EDDA 0%, #A8D5B2 100%)"
          href="/health-check/"
          buttonLabel="Kiểm tra ngay"
          buttonVariant="primary"
        />

        <Card
          title="Video dinh dưỡng"
          description="Xem các video hướng dẫn dinh dưỡng hữu ích cho bé được thực hiện bởi chuyên gia."
          icon="🎬"
          badge="Mới"
          badgeVariant="accent"
          gradient="linear-gradient(135deg, #FFF8E1 0%, #FFE082 100%)"
          href="/videos/"
          buttonLabel="Xem video"
          buttonVariant="secondary"
        />

        <Card
          title="Tạo ảnh nghề nghiệp"
          description="Dùng AI tạo ảnh bé trong trang phục nghề nghiệp tương lai — vui nhộn và ý nghĩa."
          icon="🎨"
          badge="AI"
          badgeVariant="accent"
          gradient="linear-gradient(135deg, #E8F5EC 0%, #B2DFDB 100%)"
          href="/ai-generator/"
          buttonLabel="Tạo ảnh ngay"
          buttonVariant="accent"
        />

        <Card
          title="Giải thưởng"
          description="Khám phá các giải thưởng hấp dẫn và cơ hội nhận quà khi tham gia chiến dịch."
          icon="🏆"
          badge="Hot"
          badgeVariant="primary"
          gradient="linear-gradient(135deg, #FFF8E1 0%, #FFCC80 100%)"
          href="/awards/"
          buttonLabel="Xem giải thưởng"
          buttonVariant="secondary"
        />
      </div>
    </div>
  </section>

  <!-- ===== 4. Contact Form Section ===== -->
  <section id="contact" class="section fade-up">
    <div class="container">
      <SectionHeader
        badge="Liên hệ"
        title="Liên Hệ Với Chúng Tôi"
        subtitle="Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn. Hãy để lại thông tin và chúng tôi sẽ phản hồi sớm nhất."
        align="center"
      />

      <div class="contact-wrapper">
        <GlassPanel variant="leaf" class="contact-panel">
          <form class="contact-form" novalidate>
            <div class="form-group">
              <label for="full-name" class="form-label">Họ tên</label>
              <input
                type="text"
                id="full-name"
                name="full-name"
                class="form-input"
                placeholder="Nguyễn Văn A"
                required
              />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="example@email.com"
                required
              />
            </div>

            <div class="form-group">
              <label for="phone" class="form-label">Số điện thoại</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="form-input"
                placeholder="0912 345 678"
              />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Tin nhắn</label>
              <textarea
                id="message"
                name="message"
                class="form-input form-textarea"
                placeholder="Nhập nội dung tin nhắn của bạn..."
                rows="4"
                required
              ></textarea>
            </div>

            <Button variant="primary" size="lg" fullWidth>
              Gửi tin nhắn
            </Button>
          </form>
        </GlassPanel>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ===== Hero Section ===== */
  .hero {
    min-height: 80vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero-blob-1 {
    width: 500px;
    height: 500px;
    top: -100px;
    left: -150px;
  }

  .hero-blob-2 {
    width: 400px;
    height: 400px;
    bottom: -80px;
    right: -100px;
  }

  .hero-blob-3 {
    width: 300px;
    height: 300px;
    top: 50%;
    right: 10%;
    transform: translateY(-50%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-block: 80px;
  }

  /* Hero badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
  }

  .badge-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .badge-text {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    color: var(--color-primary-dark);
    letter-spacing: 0.5px;
  }

  /* Hero heading */
  .hero-title {
    color: var(--color-heading);
    font-size: 48px;
    font-weight: 800;
    line-height: 1.15;
    text-shadow: 0 2px 16px rgba(61, 139, 79, 0.12);
    max-width: 700px;
  }

  /* Hero subtitle */
  .hero-subtitle {
    font-size: 20px;
    color: var(--color-body);
    opacity: 0.85;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  /* Hero CTA buttons */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    padding: 15px 32px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    border: none;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-primary-dark);
    box-shadow: 0 4px 16px rgba(61, 139, 79, 0.15), inset 0 1px 0 rgba(255,255,255,0.8);
    transition: filter 0.2s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .btn-hero-primary:hover {
    filter: brightness(1.04);
    transform: translateY(-1px);
  }

  .btn-hero-primary:active {
    transform: translateY(1px);
  }

  .btn-hero-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    padding: 15px 32px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-heading);
    border: 1.5px solid rgba(94, 170, 110, 0.35);
    transition: background 0.2s ease, transform 0.1s ease;
    white-space: nowrap;
  }

  .btn-hero-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
  }

  .btn-hero-secondary:active {
    transform: translateY(1px);
  }

  .play-icon {
    font-size: 12px;
  }

  /* ===== Product Section ===== */
  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-top: 48px;
  }

  .product-image-placeholder {
    min-height: 320px;
    border-radius: var(--radius-card-lg);
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-primary-dark) 60%,
      #2D6B40 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-4);
  }

  .product-image-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    padding: 24px;
  }

  .product-image-label {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .product-image-sub {
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .product-description {
    font-size: 16px;
    line-height: 1.8;
    color: var(--color-body);
  }

  .vitamin-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .vitamin-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: var(--radius-card);
  }

  .vitamin-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-icon);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 14px;
    color: #fff;
    flex-shrink: 0;
  }

  .vitamin-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .vitamin-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    color: var(--color-heading);
    line-height: 1.2;
  }

  .vitamin-benefit {
    font-size: 11px;
    color: var(--color-muted);
    line-height: 1.4;
  }

  /* ===== Campaign Section ===== */
  .campaign-blob-1 {
    width: 450px;
    height: 450px;
    top: -80px;
    right: -120px;
  }

  .campaign-blob-2 {
    width: 350px;
    height: 350px;
    bottom: -60px;
    left: -80px;
  }

  .campaign-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
    position: relative;
    z-index: 1;
  }

  /* ===== Contact Section ===== */
  .contact-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  .contact-panel {
    width: 100%;
    max-width: 600px;
    padding: 40px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-heading);
  }

  .form-input {
    border-radius: 12px;
    border: 2px solid var(--color-leaf-gray);
    background: var(--color-cream);
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-heading);
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--color-muted);
  }

  .form-input:focus {
    border-color: var(--color-primary-light);
    box-shadow: 0 0 0 3px rgba(94, 170, 110, 0.12);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .hero-title {
      font-size: 38px;
    }

    .campaign-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-image-placeholder {
      min-height: 240px;
    }

    .campaign-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 28px;
    }

    .hero-subtitle {
      font-size: 16px;
    }

    .vitamin-grid {
      grid-template-columns: 1fr;
    }

    .campaign-grid {
      grid-template-columns: 1fr;
    }

    .contact-panel {
      padding: 24px 20px;
    }
  }
</style>
